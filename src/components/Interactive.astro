<section class="px-6 py-16 md:px-10 lg:px-16 lg:py-24">
  <div class="max-w-6xl mx-auto lg:flex lg:items-end lg:gap-0 relative">
    <!-- Imagen -->
    <div class="lg:w-3/5">
      <picture>
        <source media="(min-width: 768px)" srcset="/images/desktop/image-interactive.jpg" />
        <img
          src="/images/mobile/image-interactive.jpg"
          alt="Interactive VR"
          class="w-full"
        />
      </picture>
    </div>

    <!-- Texto - se superpone en desktop -->
    <div class="mt-8 lg:mt-0 lg:absolute lg:bottom-0 lg:right-0 lg:w-1/2 lg:bg-white lg:pl-16 lg:pt-16">
      <h2 class="font-josefin text-black text-3xl md:text-4xl uppercase font-light mb-4">
        The Leader in Interactive VR
      </h2>
      <p class="font-alata text-gray-500 text-sm leading-relaxed">
        Founded in 2011, Loopstudios has been producing world-class virtual reality projects for some of the best companies around the globe. Our award-winning creations have transformed businesses through digital experiences that bind to their future.
      </p>
    </div>
  </div>
</section>
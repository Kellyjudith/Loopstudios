---
<footer class="bg-black px-6 py-10 md:px-10 lg:px-16">
  <div class="max-w-6xl mx-auto">
    <div class="flex flex-col items-center gap-8 md:flex-row md:justify-between md:items-start">
      <!-- Logo + Nav -->
      <div class="flex flex-col items-center gap-8 md:items-start">
        <a href="/">
          <img src="/logo.svg" alt="Loopstudios" class="w-36" />
        </a>
        <nav class="flex flex-col items-center gap-4 md:flex-row md:gap-6">
          <a href="#" class="text-white font-alata text-sm hover:border-b-2 hover:border-white pb-1 transition-all">About</a>
          <a href="#" class="text-white font-alata text-sm hover:border-b-2 hover:border-white pb-1 transition-all">Careers</a>
          <a href="#" class="text-white font-alata text-sm hover:border-b-2 hover:border-white pb-1 transition-all">Events</a>
          <a href="#" class="text-white font-alata text-sm hover:border-b-2 hover:border-white pb-1 transition-all">Products</a>
          <a href="#" class="text-white font-alata text-sm hover:border-b-2 hover:border-white pb-1 transition-all">Support</a>
        </nav>
      </div>

      <!-- Redes + Copyright -->
      <div class="flex flex-col items-center gap-4 md:items-end">
        <div class="flex gap-4">
          <a href="#" class="hover:opacity-70 transition-opacity" aria-label="Facebook">
            <img src="/icon-facebook.svg" alt="Facebook" class="w-5" />
          </a>
          <a href="#" class="hover:opacity-70 transition-opacity" aria-label="Twitter">
            <img src="/icon-twitter.svg" alt="Twitter" class="w-5" />
          </a>
          <a href="#" class="hover:opacity-70 transition-opacity" aria-label="Pinterest">
            <img src="/icon-pinterest.svg" alt="Pinterest" class="w-5" />
          </a>
          <a href="#" class="hover:opacity-70 transition-opacity" aria-label="Instagram">
            <img src="/icon-instagram.svg" alt="Instagram" class="w-5" />
          </a>
        </div>
        <p class="text-gray200 font-alata text-sm">
          © 2021 Loopstudios. All rights reserved.
        </p>
      </div>
    </div>
  </div>
</footer>